# Web enrichment search provider.
# Allowed values: auto, searxng, duckduckgo, brave, none
# Auto tries local SearXNG, then DuckDuckGo if installed, then Brave if a key is present.
ENRICHMENT_SEARCH_PROVIDER=auto

# Optional local SearXNG endpoint. Only use an instance you control.
SEARXNG_BASE_URL=http://localhost:8080

# Optional paid Brave Search API key. Required only when ENRICHMENT_SEARCH_PROVIDER=brave.
BRAVE_SEARCH_API_KEY=

# Optional: force broad-search cache refresh during enrichment previews.
ENRICHMENT_SEARCH_CACHE_REFRESH=false
